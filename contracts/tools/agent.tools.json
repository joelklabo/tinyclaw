{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tinyclaw.dev/contracts/tools/agent.tools.json",
  "title": "Agent Tool Output",
  "description": "Schema for agent.run task output.",
  "type": "object",
  "properties": {
    "runId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "cancelled"]
    },
    "response": { "type": "string" },
    "toolCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "toolName": { "type": "string" },
          "input": { "type": "object" },
          "output": { "type": "object" }
        },
        "required": ["toolName"]
      }
    },
    "error": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["auth", "quota", "transient", "fatal"]
        },
        "message": { "type": "string" }
      },
      "required": ["kind", "message"]
    }
  },
  "required": ["runId", "status"]
}
